<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   Version="12.0"
                   ExtensionBundleId="com.falldamage.papereditor"
                   ExtensionBundleName="Paper Editor"
                   ExtensionBundleVersion="1.0.0">

    <ExtensionList>
        <Extension Id="com.falldamage.papereditor.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- Premiere Pro 2025 (v25.x) and 2026 (v26.x) -->
            <Host Name="PPRO" Version="[25.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="12.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.falldamage.papereditor.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Paper Editor</Menu>
                    <Geometry>
                        <Size>
                            <Height>900</Height>
                            <Width>420</Width>
                        </Size>
                        <MinSize>
                            <Height>600</Height>
                            <Width>360</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2000</Height>
                            <Width>800</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons />
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>

</ExtensionManifest>
